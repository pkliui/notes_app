generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]  // binaries for Alpine Linux Docker
}

datasource db {
  provider = "postgresql"
}

model Note {
  id      Int    @id @default(autoincrement())
  title   String
  content String
}
